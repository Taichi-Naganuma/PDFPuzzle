<Window x:Class="PDFPuzzle.Property"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        Height="360" Width="500" MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- Split -->
            <TabItem Header="{DynamicResource Settings_Tab_Split}">
                <StackPanel Margin="12">
                    <TextBlock Text="{DynamicResource Settings_Split_Options}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Split_PageCount}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="SplitPageCountBox" Width="60" Text="1"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Extract -->
            <TabItem Header="{DynamicResource Settings_Tab_Extract}">
                <StackPanel Margin="12">
                    <TextBlock Text="{DynamicResource Settings_Extract_Options}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Extract_PageRange}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="ExtractPageRangeBox" Width="160" ToolTip="例: 1,3,5-8"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Extract_PageRangeNote}"
                               Foreground="#757575" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- Output -->
            <TabItem Header="{DynamicResource Settings_Tab_Output}">
                <StackPanel Margin="12">
                    <TextBlock Text="{DynamicResource Settings_Output_Options}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="OpenFolderCheckBox" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Output_OpenFolder}" TextWrapping="Wrap" MaxWidth="400"/>
                    </CheckBox>
                </StackPanel>
            </TabItem>

            <!-- Language -->
            <TabItem Header="{DynamicResource Settings_Language}">
                <StackPanel Margin="12">
                    <ComboBox x:Name="LanguageComboBox" Width="160" HorizontalAlignment="Left"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Tag="ja">日本語</ComboBoxItem>
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Button Grid.Row="1" Content="{DynamicResource Btn_OK}"
                HorizontalAlignment="Right" Width="80" Margin="0,12,0,0"
                Click="OK_Button_Click"/>
    </Grid>
</Window>
