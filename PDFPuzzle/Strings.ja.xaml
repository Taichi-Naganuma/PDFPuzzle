    <sys:String x:Key="Status_Processing">処理中...</sys:String>
    <sys:String x:Key="Status_Done">完了</sys:String>

    <sys:String x:Key="Settings_Title">設定</sys:String>
    <sys:String x:Key="Settings_Tab_Split">分割</sys:String>
    <sys:String x:Key="Settings_Tab_Extract">ページ抽出</sys:String>
    <sys:String x:Key="Settings_Tab_Output">出力設定</sys:String>
    <sys:String x:Key="Settings_Language">言語 / Language</sys:String>
    <sys:String x:Key="Settings_Split_Options">分割オプション</sys:String>
