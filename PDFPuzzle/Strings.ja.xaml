    <sys:String x:Key="License_ErrorEmpty">ライセンスキーを入力してください。</sys:String>
    <sys:String x:Key="License_ErrorInvalid">無効なライセンスキーです。</sys:String>
    <sys:String x:Key="License_ErrorNetwork">ネットワークエラー。インターネット接続を確認してください。</sys:String>

