    <sys:String x:Key="Workflow_ErrorEmpty">ワークフロー名を入力してください。</sys:String>
    <sys:String x:Key="Workflow_ConfirmOverwrite">同名のワークフローが既に存在します。上書きしますか？</sys:String>
    <sys:String x:Key="Workflow_ConfirmDelete">「{0}」を削除します。よろしいですか？</sys:String>
    <sys:String x:Key="Workflow_Load_Empty">保存済みのワークフローはありません。</sys:String>
    <sys:String x:Key="Workflow_Load_NoSelection">ワークフローを選択してください。</sys:String>
    <sys:String x:Key="Workflow_Save_NoSteps">パイプラインに処理が登録されていません。</sys:String>
    <sys:String x:Key="Workflow_Load_Failed">ワークフローを読込めませんでした。処理メニューに存在しない項目が含まれています。</sys:String>
    <sys:String x:Key="Status_WorkflowSaved">ワークフローを保存しました</sys:String>
    <sys:String x:Key="Status_WorkflowLoaded">ワークフローを読込みました</sys:String>

</ResourceDictionary>
