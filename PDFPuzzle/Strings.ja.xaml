    <sys:String x:Key="Workflow_Save_Title">ワークフローを保存</sys:String>
    <sys:String x:Key="Workflow_Load_Title">ワークフローを読込</sys:String>
    <sys:String x:Key="Workflow_NameLabel">ワークフロー名</sys:String>
    <sys:String x:Key="Workflow_Save_OK">保存</sys:String>
    <sys:String x:Key="Workflow_Load_OK">読込</sys:String>
    <sys:String x:Key="Workflow_Cancel">キャンセル</sys:String>
