    <sys:String x:Key="Settings_Output_Options">出力オプション</sys:String>
    <sys:String x:Key="Settings_Output_OpenFolder">処理完了後、出力フォルダを自動で開く</sys:String>
    <sys:String x:Key="Btn_OK">OK</sys:String>

    <sys:String x:Key="Method_Merge">PDFを結合</sys:String>
    <sys:String x:Key="Method_Split">PDFを分割</sys:String>
    <sys:String x:Key="Method_Extract">ページを抽出</sys:String>

