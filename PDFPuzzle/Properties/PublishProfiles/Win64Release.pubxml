<?xml version="1.0" encoding="utf-8"?>
<!--
  PDFPuzzle Release Publish Profile (Self-contained / win-x64)
  ============================================================
  Generated: 2026-05-11 (Sala / 5月v1 完成版納品基盤)

  目的:
    - 5月v1 完成版ビルド (1.0.0) 用の Release publish 構成
    - Self-contained により .NET ランタイム同梱、エンドユーザの追加インストール不要
    - PdfSharpCore / PdfPig との互換性を最優先（SingleFile / Trimmed / R2R は無効化）

  使用:
    installer\build_release_setup.bat 経由で MSBuild に PublishProfile=Win64Release を渡して呼び出す。
    手動で実行する場合は以下:
      MSBuild PDFPuzzle\PDFPuzzle.csproj /t:Publish /p:PublishProfile=Win64Release /p:Configuration=Release

  出力:
    リポジトリルート直下の publish\ ディレクトリ (PublishDir=..\..\publish)。
    Inno Setup の Source パス (..\publish\*) と整合。
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
