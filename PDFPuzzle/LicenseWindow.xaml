<Window x:Class="PDFPuzzle.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource License_Title}"
        Height="540" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource License_Title}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,12"/>

        <!-- 説明文 -->
        <TextBlock Grid.Row="1"
                   Text="{DynamicResource License_Instruction}"
                   TextWrapping="Wrap" Foreground="#424242"
                   FontSize="12" Margin="0,0,0,12"/>

        <!-- 現在のライセンス階層 -->
        <TextBlock Grid.Row="2"
                   FontSize="11" Foreground="#1565C0"
                   Margin="0,0,0,8">
            <Run Text="{DynamicResource License_CurrentTier_Prefix}"/>
            <Run x:Name="CurrentTierText" FontWeight="Bold"/>
        </TextBlock>

        <!-- 機能リスト見出し -->
        <TextBlock Grid.Row="3"
                   Text="{DynamicResource License_Features_Heading}"
                   FontWeight="SemiBold" Foreground="#424242"
                   FontSize="12" Margin="0,4,0,6"/>

        <!-- 機能リスト（個人版） -->
        <StackPanel x:Name="PersonalFeaturesPanel" Grid.Row="4" Margin="8,0,0,8" Visibility="Collapsed">
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Personal_1}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Personal_2}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Personal_3}"/>
            </TextBlock>
        </StackPanel>

        <!-- 機能リスト（事業者版） -->
        <StackPanel x:Name="BusinessFeaturesPanel" Grid.Row="4" Margin="8,0,0,8" Visibility="Collapsed">
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Business_1}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Business_2}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Business_3}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Business_4}"/>
            </TextBlock>
        </StackPanel>

        <!-- 機能リスト（チーム版） -->
        <StackPanel x:Name="TeamFeaturesPanel" Grid.Row="4" Margin="8,0,0,8" Visibility="Collapsed">
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Team_1}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Team_2}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Team_3}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#424242" Margin="0,0,0,2">
                <Run Text="&#x2022;  "/>
                <Run Text="{DynamicResource License_Features_Team_4}"/>
            </TextBlock>
        </StackPanel>

        <!-- CTA: 事業者版へアップグレード（個人版のみ表示） -->
        <Button x:Name="UpgradeCtaButton" Grid.Row="5"
                Content="{DynamicResource License_Upgrade_Cta}"
                Height="34" Margin="0,4,0,12"
                Background="#1565C0" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed"
                Click="UpgradeCtaButton_Click"/>

        <!-- 席数管理（チーム版のみ表示・UpgradeCtaButton と同じ Row 5・排他制御） -->
        <Button x:Name="ManageSeatsButton" Grid.Row="5"
                Content="{DynamicResource License_ManageSeats}"
                Height="34" Margin="0,4,0,12"
                Background="#1565C0" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed"
                Click="ManageSeatsButton_Click"/>

        <!-- ライセンスキーラベル -->
        <TextBlock Grid.Row="6"
                   Text="{DynamicResource License_KeyLabel}"
                   FontWeight="SemiBold" Foreground="#424242"
                   FontSize="12" Margin="0,0,0,6"/>

        <!-- ライセンスキー入力 -->
        <TextBox x:Name="LicenseKeyBox" Grid.Row="7"
                 Height="36" FontSize="13"
                 VerticalContentAlignment="Center" Padding="8,0"
                 BorderBrush="#BDBDBD" BorderThickness="1"/>

        <!-- エラー・ステータスメッセージ -->
        <TextBlock x:Name="StatusText" Grid.Row="8"
                   TextWrapping="Wrap" FontSize="11"
                   Margin="0,8,0,0" VerticalAlignment="Top"/>

        <!-- ボタン行 -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                <Hyperlink x:Name="BuyLink" NavigateUri="https://gumroad.com"
                           RequestNavigate="BuyLink_RequestNavigate">
                    <Run Text="{DynamicResource License_BuyLink}"/>
                </Hyperlink>
            </TextBlock>

            <Button x:Name="CancelButton" Grid.Column="1"
                    Content="{DynamicResource License_Cancel}"
                    Width="80" Height="34"
                    Click="CancelButton_Click"/>

            <Button x:Name="ActivateButton" Grid.Column="3"
                    Content="{DynamicResource License_Activate}"
                    Width="100" Height="34"
                    Background="#1565C0" Foreground="White"
                    FontWeight="Bold" BorderThickness="0"
                    Click="ActivateButton_Click"/>
        </Grid>
    </Grid>
</Window>

