<Window x:Class="PDFPuzzle.WorkflowLoadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Workflow_Load_Title}"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinHeight="320" MinWidth="420">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Workflow_Load_Title}"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <ListBox x:Name="WorkflowList"
                     BorderBrush="#E0E0E0" BorderThickness="1"
                     SelectionMode="Single" MouseDoubleClick="WorkflowList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="13" Foreground="#212121"/>
                            <TextBlock Grid.Row="1" FontSize="11" Foreground="#757575" Margin="0,2,0,0">
                                <Run Text="{Binding StepSummary, Mode=OneWay}"/>
                                <Run Text="  /  "/>
                                <Run Text="{Binding CreatedAtDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock x:Name="EmptyHint"
                       Text="{DynamicResource Workflow_Load_Empty}"
                       Foreground="#BDBDBD" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False" Visibility="Collapsed"/>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2"
                   TextWrapping="Wrap" FontSize="11"
                   Foreground="#D32F2F" Margin="0,8,0,0"/>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{DynamicResource Workflow_Delete}"
                    Width="90" Height="32"
                    Click="DeleteButton_Click"/>

            <Button Grid.Column="2"
                    Content="{DynamicResource Workflow_Cancel}"
                    Width="80" Height="32"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="4"
                    Content="{DynamicResource Workflow_Load_OK}"
                    Width="100" Height="32"
                    Background="#1565C0" Foreground="White"
                    FontWeight="Bold" BorderThickness="0"
                    Click="LoadButton_Click" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
