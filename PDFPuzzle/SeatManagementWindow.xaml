<Window x:Class="PDFPuzzle.SeatManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Seat_Title}"
        Height="520" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Seat_Title}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,12"/>

        <!-- ライセンスキー（マスク表示） -->
        <TextBlock Grid.Row="1" FontSize="12" Foreground="#424242" Margin="0,0,0,4">
            <Run Text="{DynamicResource Seat_KeyLabel}"/>
            <Run x:Name="MaskedKeyText" FontWeight="SemiBold" FontFamily="Consolas"/>
        </TextBlock>

        <!-- 席数テキスト -->
        <TextBlock Grid.Row="2" FontSize="12" Foreground="#424242" Margin="0,8,0,4">
            <Run Text="{DynamicResource Seat_CountLabel}"/>
            <Run x:Name="SeatCountText" FontWeight="Bold" Foreground="#1565C0"/>
            <Run Text="{DynamicResource Seat_CountSuffix}"/>
        </TextBlock>

        <!-- 席数 ProgressBar -->
        <ProgressBar x:Name="SeatProgressBar" Grid.Row="3"
                     Height="14" Margin="0,2,0,12"
                     Minimum="0" Foreground="#1565C0"/>

        <!-- 端末リスト見出し -->
        <TextBlock Grid.Row="4"
                   Text="{DynamicResource Seat_DevicesHeading}"
                   FontWeight="SemiBold" Foreground="#424242"
                   FontSize="12" Margin="0,4,0,6"/>

        <!-- 端末リスト列見出し -->
        <Grid Grid.Row="5" Margin="6,0,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="92"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Seat_Col_Machine}"
                       FontSize="11" Foreground="#757575"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource Seat_Col_User}"
                       FontSize="11" Foreground="#757575"/>
            <TextBlock Grid.Column="2" Text="{DynamicResource Seat_Col_LastUsed}"
                       FontSize="11" Foreground="#757575"/>
        </Grid>

        <!-- 端末リスト本体 -->
        <Border Grid.Row="6" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DeviceListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="6,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MachineName}"
                                                       FontSize="12" Foreground="#212121"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- 管理者席バッジ。IsAdmin が true のときのみ表示。
                                                 v0.2 は識別・表示のみ ── 権限差は無い。 -->
                                            <Border Margin="6,0,0,0" Padding="5,1"
                                                    CornerRadius="3" Background="#E3F2FD"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsAdmin,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{DynamicResource Seat_AdminBadge}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="#1565C0"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding UserName}"
                                                   FontSize="12" Foreground="#212121"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LastUsedAtDisplay}"
                                                   FontSize="11" Foreground="#757575"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="3"
                                                x:Name="ReleaseSeatButton"
                                                Content="{DynamicResource Seat_Release}"
                                                Tag="{Binding DeviceId}"
                                                Height="28" FontSize="11"
                                                Click="ReleaseSeatButton_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="EmptyHint"
                           Text="{DynamicResource Seat_DevicesEmpty}"
                           Foreground="#BDBDBD" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- ステータスメッセージ -->
        <TextBlock x:Name="StatusText" Grid.Row="7"
                   TextWrapping="Wrap" FontSize="11"
                   Margin="0,8,0,0" VerticalAlignment="Top"/>

        <!-- ボタン行 -->
        <Grid Grid.Row="8" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Name="ExportAuditCsvButton"
                    Content="{DynamicResource Seat_ExportCsv}"
                    Height="34" Padding="14,0"
                    Click="ExportAuditCsvButton_Click"/>

            <Button Grid.Column="2"
                    x:Name="CloseButton"
                    Content="{DynamicResource Seat_Close}"
                    Width="100" Height="34"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
